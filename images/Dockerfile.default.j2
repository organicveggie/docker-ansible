# ==========================================
# Stage 1: Build & Compile Dependencies
# ==========================================
FROM buildpack-deps:{{ os_release }} AS builder

RUN <<RUN_CMD_EOF
apt-get update
apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    libbz2-dev \
    libdb5.3-dev \
    libexpat1-dev \
    libffi-dev \
    libgdbm-dev \
    liblzma-dev \
    libncurses5-dev \
    libncursesw5-dev \
    libonig-dev \
    libreadline-dev \
    libsqlite3-dev \
    libssl-dev \
    libuuid1 \
    python3 \
    python3-dev \
    python3-setuptools \
    python3-pip \
    python3-yaml \
    software-properties-common \
    zlib1g-dev

# Clean up APT cache to reduce image size
apt-get clean
rm -fR /var/lib/apt/lists/*
rm -fR /usr/share/doc
rm -fR /usr/share/man
RUN_CMD_EOF

# Install dependencies into a dedicated isolated folder
RUN --mount=type=bind,source=images/requirements.txt,target=/tmp/requirements.txt <<RUN_CMD_EOF
mkdir /deps
python3 -m pip install --no-cache-dir --upgrade pip
python3 -m pip install --no-cache-dir --target=/deps -r /tmp/requirements.txt
RUN_CMD_EOF

# ==========================================
# Stage 2: Final Clean Runtime
# ==========================================

{% if os_name == 'debian' %}
FROM debian:{{ os_release }}-slim
{% else %}
FROM {{ os_name }}:{{ os_release }}
{% endif %}

# Set build-time argument for build version, with a default value
ARG IMAGE_BUILD_VERSION=v0.0.0
ENV IMAGE_BUILD_VERSION=${IMAGE_BUILD_VERSION}

ENV LANG=C.UTF-8

{% if os_name in ['debian', 'ubuntu'] -%}
# Prevent interactive prompts during installation
ENV DEBIAN_FRONTEND=noninteractive
{% endif %}

# Install runtime libraries
RUN <<RUN_CMD_EOF
apt-get update
apt-get install -y --no-install-recommends \
    curl \
    iproute2 \
    libffi8 \
    liblzma5 \
    libonig5 \
    libreadline8 \
    libsqlite3-0 \
    libssl3 \
    libbz2-1.0 \
    libuuid1 \
    locales \
    lsb-release \
    python3 \
    python3-pip \
    python3-yaml \
    rsyslog \
    software-properties-common \
    systemd \
    systemd-cron \
    sudo

# Clean up APT cache to reduce image size
apt-get clean
rm -fR /var/lib/apt/lists/*
rm -fR /usr/share/doc
rm -fR /usr/share/man
RUN_CMD_EOF

# Copy the isolated dependencies from the builder
COPY --from=builder /deps /usr/lib/python3/dist-packages

# Copy any command-line executable binaries generated by pip
COPY --from=builder /deps/bin/* /usr/local/bin/

{% include "Dockerfile.ansible.j2" %}
