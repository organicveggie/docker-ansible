# ==========================================
# Stage 1: Build & Compile Dependencies
# ==========================================
FROM buildpack-deps:26.10 AS builder

RUN <<RUN_CMD_EOF
apt-get update
apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    libbz2-dev \
    libdb5.3-dev \
    libexpat1-dev \
    libffi-dev \
    libgdbm-dev \
    liblzma-dev \
    libncurses5-dev \
    libncursesw5-dev \
    libonig-dev \
    libreadline-dev \
    libsqlite3-dev \
    libssl-dev \
    libuuid1 \
    python3 \
    python3-dev \
    python3-setuptools \
    python3-pip \
    python3-yaml \
    zlib1g-dev

# Clean up APT cache to reduce image size
apt-get clean
rm -fR /var/lib/apt/lists/*
rm -fR /usr/share/doc
rm -fR /usr/share/man
RUN_CMD_EOF

# Install dependencies into a dedicated isolated folder
RUN --mount=type=bind,source=images/requirements.txt,target=/tmp/requirements.txt <<RUN_CMD_EOF
mkdir /deps
python3 -m pip install --no-cache-dir --upgrade pip
python3 -m pip install --no-cache-dir --target=/deps -r /tmp/requirements.txt
RUN_CMD_EOF

# ==========================================
# Stage 2: Final Clean Runtime
# ==========================================


FROM ubuntu:26.10


# Set build-time argument for build version, with a default value
ARG IMAGE_BUILD_VERSION=v0.0.0
ENV IMAGE_BUILD_VERSION=${IMAGE_BUILD_VERSION}

ENV LANG=C.UTF-8

# Prevent interactive prompts during installation
ENV DEBIAN_FRONTEND=noninteractive


# Install runtime libraries
RUN <<RUN_CMD_EOF
apt-get update
apt-get install -y --no-install-recommends \
    curl \
    iproute2 \
    libffi8 \
    liblzma5 \
    libonig5 \
    libreadline8 \
    libsqlite3-0 \
    libssl3 \
    libbz2-1.0 \
    libuuid1 \
    locales \
    lsb-release \
    python3 \
    python3-pip \
    python3-yaml \
    rsyslog \
    systemd \
    systemd-cron \
    sudo

# Clean up APT cache to reduce image size
apt-get clean
rm -fR /var/lib/apt/lists/*
rm -fR /usr/share/doc
rm -fR /usr/share/man
RUN_CMD_EOF

# Copy the isolated dependencies from the builder
COPY --from=builder /deps /usr/lib/python3/dist-packages

# Copy any command-line executable binaries generated by pip
COPY --from=builder /deps/bin/* /usr/local/bin/

RUN <<RUN_CMD_EOF
# Remove useless Python environment warning flag.
rm -rf /usr/lib/python3.14/EXTERNALLY-MANAGED

sed -i 's/^\($ModLoad imklog\)/#\1/' /etc/rsyslog.conf

# Fix potential UTF-8 errors with ansible-test.
locale-gen en_US.UTF-8
RUN_CMD_EOF

COPY images/initctl_faker .
RUN <<RUN_CMD_EOF
chmod +x initctl_faker
rm -fr /sbin/initctl
ln -s /initctl_faker /sbin/initctl
RUN_CMD_EOF

# Install Ansible inventory file.
RUN <<RUN_CMD_EOF
mkdir -p /etc/ansible
echo "[local]\nlocalhost ansible_connection=local" > /etc/ansible/hosts
RUN_CMD_EOF

# Remove unnecessary getty and udev targets that result in high CPU usage when using
# multiple containers with Molecule (https://github.com/ansible/molecule/issues/1104)
RUN <<RUN_CMD_EOF
rm -f /lib/systemd/system/systemd*udev*
rm -f /lib/systemd/system/getty.target
RUN_CMD_EOF

# Define image labels
LABEL org.opencontainers.image.authors="Sean Laurent" \
    org.opencontainers.image.base.name="buildpack-deps:26.10-curl" \
    org.opencontainers.image.description="Docker image for Ansible role testing with Python 3.14 on Ubuntu 26.10" \
    org.opencontainers.image.licenses="GPL-3.0-or-later" \
    org.opencontainers.image.source="https://github.com/organicveggie/docker-ansible" \
    org.opencontainers.image.title="organicveggie/docker-ansible" \
    org.opencontainers.image.version="${IMAGE_BUILD_VERSION}"

VOLUME ["/sys/fs/cgroup", "/tmp", "/run"]
CMD ["/lib/systemd/systemd"]